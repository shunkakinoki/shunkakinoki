{
  "name": "shunkakinoki",
  "author": "Shun Kakinoki",
  "license": "MIT",
  "version": "4.22.19",
  "homepage": "https://github.com/shunkakinoki/shunkakinoki",
  "repository": {
    "type": "git",
    "url": "https://github.com/shunkakinoki/shunkakinoki.git"
  },
  "scripts": {
    "build": "gatsby build",
    "dev": "gatsby develop",
    "clean": "gatsby clean",
    "test": "yarn lint && yarn release-test",
    "release": "semantic-release",
    "release-test": "semantic-release -d",
    "lint": "yarn eclint-check && yarn eslint-check && yarn prettier-check",
    "fix": "yarn eclint-fix && yarn eslint-fix && yarn prettier-fix",
    "eclint-check": "eclint check $(git ls-files)",
    "eclint-fix": "eclint fix $(git ls-files)",
    "eslint-check": "eslint . --ext js,jsx,ts,tsx --max-warnings=0",
    "eslint-fix": "eslint . --ext js,jsx,ts,tsx --fix --max-warnings=0",
    "prettier-check": "prettier --check \"**/*.{js,jsx,json,ts,tsx,css,html,yml,yaml,scss,sass}\"",
    "prettier-fix": "prettier --write \"**/*.{js,jsx,json,ts,tsx,css,html,yml,yaml,scss,sass}\""
  },
  "dependencies": {
    "@emotion/styled": "^10.0.27",
    "@narative/gatsby-theme-novela": "^0.*",
    "gatsby": "^2.20.2",
    "gatsby-plugin-google-analytics": "^2.2.0",
    "gatsby-plugin-i18n": "^1.0.1",
    "gatsby-plugin-mailchimp": "^5.1.2",
    "gatsby-plugin-manifest": "^2.3.1",
    "prettier": "^2.0.1",
    "react": "^16.13.1",
    "react-dom": "^16.13.1"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^5.0.0",
    "@semantic-release/exec": "^5.0.0",
    "@types/node": "^13.9.2",
    "@types/react": "^16.9.25",
    "@typescript-eslint/eslint-plugin": "^2.24.0",
    "commitizen": "^4.0.3",
    "eclint": "^2.8.1",
    "eslint": "^6.2.2",
    "eslint-config-airbnb-base": "^14.1.0",
    "eslint-config-prettier": "^6.10.1",
    "eslint-plugin-prettier": "^3.1.0",
    "eslint-plugin-react": "^7.19.0",
    "eslint-plugin-unicorn": "^17.2.0",
    "git-cz": "^4.3.1",
    "husky": "^4.2.3",
    "semantic-release": "^17.0.4",
    "typescript": "^3.8.3"
  },
  "husky": {
    "hooks": {
      "prepare-commit-msg": "exec < /dev/tty && git-cz --hook || true"
    }
  }
}
